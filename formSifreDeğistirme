        private void BtnDogrula_Click(object? sender, EventArgs e)
        {
            var kullaniciAdi = txtKullaniciAdi.Text.Trim();
            var cevap = txtGuvenlikCevabi.Text.Trim();

            if (string.IsNullOrWhiteSpace(kullaniciAdi))
            {
                ShowUyari("Kullanıcı adını giriniz.", Color.FromArgb(244, 67, 54));
                return;
            }

            if (string.IsNullOrWhiteSpace(cevap))
            {
                ShowUyari("Güvenlik sorusunun cevabını giriniz.", Color.FromArgb(244, 67, 54));
                return;
            }

            // Kullanıcıyı bul
            var yonetici = DatabaseHelper.KullaniciBul(kullaniciAdi);
            if (yonetici == null)
            {
                ShowUyari("Kullanıcı bulunamadı!", Color.FromArgb(244, 67, 54));
                return;
            }

            // Güvenlik cevabını kontrol et
            if (!DatabaseHelper.GuvenlikCevabiKontrol(kullaniciAdi, cevap))
            {
                ShowUyari("Güvenlik sorusunun cevabı yanlış!", Color.FromArgb(244, 67, 54));
                return;
            }

            // Doğrulama başarılı
            kullaniciDogrulandi = true;
            dogrulanmisKullanici = kullaniciAdi;
            ShowUyari("✅ Kimlik doğrulandı!", Color.FromArgb(76, 175, 80));

            // Adım 1'i kilitle
            txtKullaniciAdi.Enabled = false;
            txtGuvenlikCevabi.Enabled = false;

            // Adım 2'yi göster
            pnlAdim2.Visible = true;
            this.Size = new Size(440, 530);
            txtYeniSifre.Focus();
        }

        private void BtnSifreDegistir_Click(object? sender, EventArgs e)
        {
            if (!kullaniciDogrulandi)
            {
                ShowUyari("Önce kimliğinizi doğrulayın.", Color.FromArgb(244, 67, 54));
                return;
            }

            var yeniSifre = txtYeniSifre.Text;
            var yeniSifreTekrar = txtYeniSifreTekrar.Text;

            if (string.IsNullOrWhiteSpace(yeniSifre))
            {
                ShowUyari("Yeni şifreyi giriniz.", Color.FromArgb(244, 67, 54));
                return;
            }

            if (yeniSifre.Length < 4)
            {
                ShowUyari("Şifre en az 4 karakter olmalıdır.", Color.FromArgb(244, 67, 54));
                return;
            }

            if (yeniSifre != yeniSifreTekrar)
            {
                ShowUyari("Şifreler eşleşmiyor!", Color.FromArgb(244, 67, 54));
                return;
            }

            // Şifreyi değiştir
            DatabaseHelper.SifreDegistir(dogrulanmisKullanici, yeniSifre);
            MessageBox.Show("Şifreniz başarıyla değiştirildi!\nYeni şifrenizle giriş yapabilirsiniz.",
                "Şifre Değiştirildi", MessageBoxButtons.OK, MessageBoxIcon.Information);
            this.DialogResult = DialogResult.OK;
            this.Close();
        }

        private void ShowUyari(string mesaj, Color renk)
        {
            lblUyari.Text = mesaj;
            lblUyari.ForeColor = renk;
            lblUyari.Visible = true;
        }
