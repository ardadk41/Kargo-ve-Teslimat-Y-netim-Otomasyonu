using KargoYonetim.Data;

namespace KargoYonetim.Forms
{
    public class FormGiris : Form
    {
        private TextBox txtKullaniciAdi = null!, txtSifre = null!;
        private Button btnGiris = null!;
        private LinkLabel lnkSifremiUnuttum = null!;
        private Label lblUyari = null!, lblBaslik = null!, lblKalan = null!;
        private int basarisizDeneme = 0;
        private const int MaxDeneme = 3;

        public bool GirisBasarili { get; private set; } = false;

        public FormGiris()
        {
            InitializeComponents();
        }

        private void InitializeComponents()
        {
            this.Text = "🔐 Yönetici Girişi";
            this.Size = new Size(460, 520);
            this.StartPosition = FormStartPosition.CenterScreen;
            this.FormBorderStyle = FormBorderStyle.FixedDialog;
            this.MaximizeBox = false;
            this.MinimizeBox = false;
            this.Font = new Font("Segoe UI", 10);
            this.BackColor = Color.FromArgb(236, 240, 241);

            // Header panel
            var pnlHeader = new Panel
            {
                Dock = DockStyle.Top,
                Height = 100,
                BackColor = Color.FromArgb(27, 40, 56)
            };
            var lblHeader = new Label
            {
                Text = "📦 Kargo ve Teslimat\n     Yönetim Otomasyonu",
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 16, FontStyle.Bold),
                Dock = DockStyle.Fill,
                TextAlign = ContentAlignment.MiddleCenter
            };
            pnlHeader.Controls.Add(lblHeader);
            this.Controls.Add(pnlHeader);

            // Login panel
            var pnlLogin = new Panel
            {
                Location = new Point(40, 120),
                Size = new Size(370, 350),
                BackColor = Color.White
            };
            pnlLogin.Paint += (s, e) =>
            {
                ControlPaint.DrawBorder(e.Graphics, pnlLogin.ClientRectangle,
                    Color.FromArgb(200, 200, 200), ButtonBorderStyle.Solid);
            };
            this.Controls.Add(pnlLogin);

            // Lock icon + title
            lblBaslik = new Label
            {
                Text = "🔐 Yönetici Girişi",
                Font = new Font("Segoe UI", 14, FontStyle.Bold),
                ForeColor = Color.FromArgb(27, 40, 56),
                Location = new Point(15, 15),
                AutoSize = true
            };
            pnlLogin.Controls.Add(lblBaslik);

            // Separator
            var separator = new Panel
            {
                Location = new Point(15, 50),
                Size = new Size(340, 2),
                BackColor = Color.FromArgb(33, 150, 243)
            };
            pnlLogin.Controls.Add(separator);

            // Kullanıcı Adı
            pnlLogin.Controls.Add(new Label
            {
                Text = "Kullanıcı Adı:",
                Location = new Point(20, 70),
                AutoSize = true,
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                ForeColor = Color.FromArgb(60, 60, 60)
            });
            txtKullaniciAdi = new TextBox
            {
                Location = new Point(20, 95),
                Size = new Size(330, 32),
                Font = new Font("Segoe UI", 12),
                BorderStyle = BorderStyle.FixedSingle
            };
            txtKullaniciAdi.KeyDown += TxtInput_KeyDown;
            pnlLogin.Controls.Add(txtKullaniciAdi);

            // Şifre
            pnlLogin.Controls.Add(new Label
            {
                Text = "Şifre:",
                Location = new Point(20, 140),
                AutoSize = true,
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                ForeColor = Color.FromArgb(60, 60, 60)
            });
            txtSifre = new TextBox
            {
                Location = new Point(20, 165),
                Size = new Size(330, 32),
                Font = new Font("Segoe UI", 12),
                BorderStyle = BorderStyle.FixedSingle,
                UseSystemPasswordChar = true
            };
            txtSifre.KeyDown += TxtInput_KeyDown;
            pnlLogin.Controls.Add(txtSifre);

            // Warning label
            lblUyari = new Label
            {
                Text = "",
                Location = new Point(20, 205),
                Size = new Size(330, 22),
                ForeColor = Color.FromArgb(244, 67, 54),
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                TextAlign = ContentAlignment.MiddleCenter,
                Visible = false
            };
            pnlLogin.Controls.Add(lblUyari);

            // Kalan deneme label
            lblKalan = new Label
            {
                Text = "",
                Location = new Point(20, 227),
                Size = new Size(330, 18),
                ForeColor = Color.FromArgb(255, 152, 0),
                Font = new Font("Segoe UI", 8),
                TextAlign = ContentAlignment.MiddleCenter,
                Visible = false
            };
            pnlLogin.Controls.Add(lblKalan);

            // Giriş button
            btnGiris = new Button
            {
                Text = "🔑  Giriş Yap",
                Location = new Point(20, 255),
                Size = new Size(330, 42),
                FlatStyle = FlatStyle.Flat,
                BackColor = Color.FromArgb(33, 150, 243),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 12, FontStyle.Bold),
                Cursor = Cursors.Hand
            };
            btnGiris.FlatAppearance.BorderSize = 0;
            btnGiris.Click += BtnGiris_Click;
            pnlLogin.Controls.Add(btnGiris);

            // Şifremi unuttum link
            lnkSifremiUnuttum = new LinkLabel
            {
                Text = "Şifremi Unuttum",
                Location = new Point(115, 310),
                AutoSize = true,
                Font = new Font("Segoe UI", 10),
                LinkColor = Color.FromArgb(33, 150, 243),
                ActiveLinkColor = Color.FromArgb(21, 101, 192),
                Visible = false
            };
            lnkSifremiUnuttum.LinkClicked += LnkSifremiUnuttum_LinkClicked;
            pnlLogin.Controls.Add(lnkSifremiUnuttum);

            this.AcceptButton = btnGiris;
        }

        private void TxtInput_KeyDown(object? sender, KeyEventArgs e)
        {
            // Enter basınca giriş yap
            if (e.KeyCode == Keys.Enter)
            {
                e.SuppressKeyPress = true;
                BtnGiris_Click(sender, e);
            }
        }

        private void BtnGiris_Click(object? sender, EventArgs e)
        {
            var kullaniciAdi = txtKullaniciAdi.Text.Trim();
            var sifre = txtSifre.Text;

            if (string.IsNullOrWhiteSpace(kullaniciAdi) || string.IsNullOrWhiteSpace(sifre))
            {
                ShowUyari("Kullanıcı adı ve şifre giriniz.");
                return;
            }

            var yonetici = DatabaseHelper.GirisYap(kullaniciAdi, sifre);
            if (yonetici != null)
            {
                GirisBasarili = true;
                this.DialogResult = DialogResult.OK;
                this.Close();
            }
            else
            {
                basarisizDeneme++;
                int kalan = MaxDeneme - basarisizDeneme;

                if (kalan > 0)
                {
                    ShowUyari("Kullanıcı adı veya şifre hatalı!");
                    lblKalan.Text = $"Kalan deneme hakkı: {kalan}";
                    lblKalan.Visible = true;
                }
                else
                {
                    ShowUyari("3 başarısız deneme! Şifrenizi sıfırlayabilirsiniz.");
                    lblKalan.Visible = false;
                    btnGiris.Enabled = false;
                    btnGiris.BackColor = Color.FromArgb(180, 180, 180);
                    lnkSifremiUnuttum.Visible = true;
                    txtKullaniciAdi.Enabled = false;
                    txtSifre.Enabled = false;
                }

                txtSifre.Clear();
                txtSifre.Focus();
            }
        }

        private void ShowUyari(string mesaj)
        {
            lblUyari.Text = mesaj;
            lblUyari.Visible = true;
        }

        private void LnkSifremiUnuttum_LinkClicked(object? sender, LinkLabelLinkClickedEventArgs e)
        {
            using var formSifre = new FormSifreDegistir();
            if (formSifre.ShowDialog() == DialogResult.OK)
            {
                // Şifre değiştirildi, formu sıfırla
                basarisizDeneme = 0;
                btnGiris.Enabled = true;
                btnGiris.BackColor = Color.FromArgb(33, 150, 243);
                txtKullaniciAdi.Enabled = true;
                txtSifre.Enabled = true;
                lnkSifremiUnuttum.Visible = false;
                lblUyari.Text = "Şifreniz başarıyla değiştirildi. Yeni şifrenizle giriş yapın.";
                lblUyari.ForeColor = Color.FromArgb(76, 175, 80);
                lblUyari.Visible = true;
                lblKalan.Visible = false;
                txtKullaniciAdi.Clear();
                txtSifre.Clear();
                txtKullaniciAdi.Focus();
            }
        }
    }
}
