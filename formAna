using KargoYonetim.Data;

namespace KargoYonetim.Forms
{
    public class FormAna : Form
    {
        private Panel pnlHeader = null!;
        private Panel pnlSidebar = null!;
        private Panel pnlContent = null!;
        private Label lblToplamVal = null!, lblYoldaVal = null!, lblTeslimVal = null!;
        private Label lblIadeVal = null!, lblGecikmisVal = null!, lblHazirVal = null!, lblIptalVal = null!;

        public bool CikisYapildi { get; private set; } = false;

        // Colors
        private static readonly Color PRIMARY = Color.FromArgb(33, 150, 243);
        private static readonly Color PRIMARY_DARK = Color.FromArgb(21, 101, 192);
        private static readonly Color SIDEBAR_BG = Color.FromArgb(27, 40, 56);
        private static readonly Color SIDEBAR_HOVER = Color.FromArgb(44, 62, 80);
        private static readonly Color ACCENT = Color.FromArgb(255, 152, 0);
        private static readonly Color SUCCESS = Color.FromArgb(76, 175, 80);
        private static readonly Color DANGER = Color.FromArgb(244, 67, 54);
        private static readonly Color WARNING = Color.FromArgb(255, 193, 7);
        private static readonly Color BG_LIGHT = Color.FromArgb(236, 240, 241);

        public FormAna()
        {
            InitializeComponents();
            // Gecikmiş siparişleri güncelle
            int updated = DatabaseHelper.UpdateGecikmisSiparisler();
            if (updated > 0)
                this.Shown += (s, e) => MessageBox.Show(
                    $"{updated} sipariş 'Gecikmiş' olarak güncellendi.",
                    "Gecikmiş Sipariş Uyarısı", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            LoadDashboard();
        }

        private void InitializeComponents()
        {
            this.Text = "Kargo ve Teslimat Yönetim Otomasyonu";
            this.Size = new Size(1200, 720);
            this.StartPosition = FormStartPosition.CenterScreen;
            this.BackColor = BG_LIGHT;
            this.MinimumSize = new Size(1024, 600);
            this.Font = new Font("Segoe UI", 10);

            // Header
            pnlHeader = new Panel
            {
                Dock = DockStyle.Top,
                Height = 60,
                BackColor = SIDEBAR_BG
            };
            var lblTitle = new Label
            {
                Text = "  📦  Kargo ve Teslimat Yönetim Otomasyonu",
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 16, FontStyle.Bold),
                Dock = DockStyle.Fill,
                TextAlign = ContentAlignment.MiddleLeft
            };
            pnlHeader.Controls.Add(lblTitle);

            // Sidebar
            pnlSidebar = new Panel
            {
                Dock = DockStyle.Left,
                Width = 220,
                BackColor = SIDEBAR_BG,
                Padding = new Padding(0, 10, 0, 0)
            };

            int yPos = 10;
            string[] btnTexts = { "📦  Siparişler", "👤  Müşteriler", "🚚  Kuryeler", "📋  Teslimat Takibi", "📊  Raporlar" };
            EventHandler[] handlers = { BtnSiparis_Click, BtnMusteri_Click, BtnKurye_Click, BtnTeslimat_Click, BtnRapor_Click };

            for (int i = 0; i < btnTexts.Length; i++)
            {
                var btn = CreateSidebarButton(btnTexts[i], yPos);
                btn.Click += handlers[i];
                pnlSidebar.Controls.Add(btn);
                yPos += 50;
            }

            // Refresh button
            var btnRefresh = CreateSidebarButton("🔄  Yenile", yPos + 20);
            btnRefresh.Click += (s, e) => LoadDashboard();
            pnlSidebar.Controls.Add(btnRefresh);

            // Çıkış butonu — sol alt köşe
            var btnCikis = new Button
            {
                Text = "🚪  Çıkış Yap",
                Size = new Size(200, 42),
                FlatStyle = FlatStyle.Flat,
                BackColor = Color.FromArgb(183, 28, 28),
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 11, FontStyle.Bold),
                TextAlign = ContentAlignment.MiddleLeft,
                Padding = new Padding(10, 0, 0, 0),
                Cursor = Cursors.Hand,
                Anchor = AnchorStyles.Bottom | AnchorStyles.Left
            };
            btnCikis.FlatAppearance.BorderSize = 0;
            btnCikis.FlatAppearance.MouseOverBackColor = Color.FromArgb(211, 47, 47);
            btnCikis.Location = new Point(10, pnlSidebar.Height - 60);
            btnCikis.Click += BtnCikis_Click;
            pnlSidebar.Controls.Add(btnCikis);

            // Content
            pnlContent = new Panel
            {
                Dock = DockStyle.Fill,
                Padding = new Padding(20),
                BackColor = BG_LIGHT
            };

            this.Controls.Add(pnlContent);
            this.Controls.Add(pnlSidebar);
            this.Controls.Add(pnlHeader);

            BuildDashboard();
        }

        private Button CreateSidebarButton(string text, int yPos)
        {
            var btn = new Button
            {
                Text = text,
                Location = new Point(10, yPos),
                Size = new Size(200, 42),
                FlatStyle = FlatStyle.Flat,
                BackColor = SIDEBAR_BG,
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 11),
                TextAlign = ContentAlignment.MiddleLeft,
                Padding = new Padding(10, 0, 0, 0),
                Cursor = Cursors.Hand
            };
            btn.FlatAppearance.BorderSize = 0;
            btn.FlatAppearance.MouseOverBackColor = SIDEBAR_HOVER;
            return btn;
        }

        private void BuildDashboard()
        {
            var lblDashTitle = new Label
            {
                Text = "Dashboard — Genel Bakış",
                Font = new Font("Segoe UI", 16, FontStyle.Bold),
                ForeColor = SIDEBAR_BG,
                Location = new Point(10, 10),
                AutoSize = true
            };
            pnlContent.Controls.Add(lblDashTitle);

            // Cards row 1
            var cards = new (string title, Color color, int x, int y)[]
            {
                ("Toplam Sipariş", PRIMARY, 10, 55),
                ("Hazırlanıyor", ACCENT, 210, 55),
                ("Yolda", Color.FromArgb(0, 150, 136), 410, 55),
                ("Teslim Edildi", SUCCESS, 610, 55),
                ("İade Bekliyor", DANGER, 10, 195),
                ("Gecikmiş", Color.FromArgb(183, 28, 28), 210, 195),
                ("İptal", Color.FromArgb(117, 117, 117), 410, 195),
            };

            Label[] valueLabels = new Label[7];

            for (int i = 0; i < cards.Length; i++)
            {
                var card = cards[i];
                var pnl = new Panel
                {
                    Location = new Point(card.x, card.y),
                    Size = new Size(185, 120),
                    BackColor = Color.White
                };
                pnl.Paint += (s, e) =>
                {
                    e.Graphics.FillRectangle(new SolidBrush(card.color), 0, 0, 5, pnl.Height);
                    ControlPaint.DrawBorder(e.Graphics, pnl.ClientRectangle, Color.FromArgb(220, 220, 220), ButtonBorderStyle.Solid);
                };

                var lblCardTitle = new Label
                {
                    Text = card.title,
                    Font = new Font("Segoe UI", 10),
                    ForeColor = Color.FromArgb(100, 100, 100),
                    Location = new Point(15, 15),
                    AutoSize = true
                };

                var lblCardValue = new Label
                {
                    Text = "0",
                    Font = new Font("Segoe UI", 28, FontStyle.Bold),
                    ForeColor = card.color,
                    Location = new Point(15, 45),
                    AutoSize = true
                };

                valueLabels[i] = lblCardValue;
                pnl.Controls.Add(lblCardTitle);
                pnl.Controls.Add(lblCardValue);
                pnlContent.Controls.Add(pnl);
            }

            lblToplamVal = valueLabels[0];
            lblHazirVal = valueLabels[1];
            lblYoldaVal = valueLabels[2];
            lblTeslimVal = valueLabels[3];
            lblIadeVal = valueLabels[4];
            lblGecikmisVal = valueLabels[5];
            lblIptalVal = valueLabels[6];
        }

        private void LoadDashboard()
        {
            try
            {
                var stats = DatabaseHelper.GetDashboardStats();
                lblToplamVal.Text = stats.GetValueOrDefault("Toplam").ToString();
                lblYoldaVal.Text = stats.GetValueOrDefault("Yolda").ToString();
                lblTeslimVal.Text = stats.GetValueOrDefault("TeslimEdildi").ToString();
                lblIadeVal.Text = stats.GetValueOrDefault("IadeBekliyor").ToString();
                lblGecikmisVal.Text = stats.GetValueOrDefault("Gecikmiş").ToString();
                lblHazirVal.Text = stats.GetValueOrDefault("Hazırlanan").ToString();
                lblIptalVal.Text = stats.GetValueOrDefault("Iptal").ToString();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Dashboard yüklenirken hata: {ex.Message}", "Hata",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void BtnSiparis_Click(object? sender, EventArgs e)
        {
            new FormSiparis().ShowDialog();
            LoadDashboard();
        }

        private void BtnMusteri_Click(object? sender, EventArgs e)
        {
            new FormMusteri().ShowDialog();
        }

        private void BtnKurye_Click(object? sender, EventArgs e)
        {
            new FormKurye().ShowDialog();
        }

        private void BtnTeslimat_Click(object? sender, EventArgs e)
        {
            new FormTeslimat().ShowDialog();
            LoadDashboard();
        }

        private void BtnRapor_Click(object? sender, EventArgs e)
        {
            new FormRaporlar().ShowDialog();
        }

        private void BtnCikis_Click(object? sender, EventArgs e)
        {
            var sonuc = MessageBox.Show("Hesaptan çıkmak istiyor musunuz?", "Çıkış",
                MessageBoxButtons.YesNo, MessageBoxIcon.Question);
            if (sonuc == DialogResult.Yes)
            {
                CikisYapildi = true;
                this.Close();
            }
        }
    }
}
