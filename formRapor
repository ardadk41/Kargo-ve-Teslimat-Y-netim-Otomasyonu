        private void DgvGecikmisSiparis_CellFormatting(object? sender, DataGridViewCellFormattingEventArgs e)
        {
            if (dgvGecikmisSiparis.Columns[e.ColumnIndex].Name == "Durum" && e.Value != null)
            {
                e.CellStyle.Font = new Font("Segoe UI", 9, FontStyle.Bold);
                switch (e.Value.ToString())
                {
                    case "Gecikmiş":
                        e.CellStyle.ForeColor = Color.White;
                        e.CellStyle.BackColor = Color.FromArgb(183, 28, 28);
                        break;
                    case "İade Bekliyor":
                        e.CellStyle.ForeColor = Color.FromArgb(183, 28, 28);
                        e.CellStyle.BackColor = Color.FromArgb(255, 235, 238);
                        break;
                }
            }
