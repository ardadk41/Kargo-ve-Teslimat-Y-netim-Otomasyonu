        private DataGridView CreateDataGridView()
        {
            var dgv = new DataGridView
            {
                Dock = DockStyle.Fill, ReadOnly = true, AllowUserToAddRows = false,
                AllowUserToDeleteRows = false,
                SelectionMode = DataGridViewSelectionMode.FullRowSelect,
                AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill,
                AutoGenerateColumns = false,
                BackgroundColor = Color.White, BorderStyle = BorderStyle.None,
                RowHeadersVisible = false, Font = new Font("Segoe UI", 9),
                AlternatingRowsDefaultCellStyle = new DataGridViewCellStyle { BackColor = Color.FromArgb(245, 245, 245) },
                DefaultCellStyle = new DataGridViewCellStyle { SelectionBackColor = Color.FromArgb(33, 150, 243) }
            };
            dgv.ColumnHeadersDefaultCellStyle = new DataGridViewCellStyle
            {
                BackColor = Color.FromArgb(27, 40, 56), ForeColor = Color.White,
                Font = new Font("Segoe UI", 10, FontStyle.Bold), Padding = new Padding(5)
            };
            dgv.EnableHeadersVisualStyles = false;
            return dgv;
        }

        private Button CreateButton(string text, int x, int y, Color color)
        {
            var btn = new Button
            {
                Text = text, Location = new Point(x, y), Size = new Size(120, 36),
                FlatStyle = FlatStyle.Flat, BackColor = color, ForeColor = Color.White,
                Font = new Font("Segoe UI", 9, FontStyle.Bold), Cursor = Cursors.Hand
            };
            btn.FlatAppearance.BorderSize = 0;
            return btn;
        }

        private void LoadData()
        {
            performansData = DatabaseHelper.GetKuryePerformans();
            dgvPerformans.DataSource = performansData;

            var gecikmisList = DatabaseHelper.GetGecikmisSiparisler();
            var iadeList = DatabaseHelper.GetIadeSiparisler();
            var combined = gecikmisList.Concat(iadeList.Where(i => !gecikmisList.Any(g => g.Id == i.Id))).ToList();
            dgvGecikmisSiparis.DataSource = combined;

            pnlChart.Invalidate();
        }

        // GDI+ Bar Chart
        private void PnlChart_Paint(object? sender, PaintEventArgs e)
        {
            if (performansData.Count == 0) return;

            var g = e.Graphics;
            g.SmoothingMode = System.Drawing.Drawing2D.SmoothingMode.AntiAlias;

            int padding = 20;
            int chartX = padding + 10;
            int chartY = padding;
            int chartW = pnlChart.Width - padding * 2 - 10;
            int chartH = pnlChart.Height - padding * 2 - 20;

            if (chartW <= 0 || chartH <= 0) return;

            int barCount = performansData.Count;
            int barWidth = Math.Min(50, (chartW - 20) / Math.Max(barCount, 1) - 10);
            int spacing = (chartW - barCount * barWidth) / (barCount + 1);

            Color[] barColors = {
                Color.FromArgb(33, 150, 243),
                Color.FromArgb(76, 175, 80),
                Color.FromArgb(255, 152, 0),
                Color.FromArgb(156, 39, 176),
                Color.FromArgb(0, 150, 136),
                Color.FromArgb(244, 67, 54)
            };

            // Draw background lines
            for (int i = 0; i <= 4; i++)
            {
                int y = chartY + chartH - (chartH * i / 4);
                g.DrawLine(Pens.LightGray, chartX, y, chartX + chartW, y);
                g.DrawString($"{i * 25}%", new Font("Segoe UI", 7), Brushes.Gray, 0, y - 7);
            }

            // Draw bars
            for (int i = 0; i < barCount; i++)
            {
                var p = performansData[i];
                int barH = (int)(chartH * p.BasariOrani / 100.0);
                int x = chartX + spacing + i * (barWidth + spacing);
                int y = chartY + chartH - barH;

                var color = barColors[i % barColors.Length];
                using var brush = new SolidBrush(color);
                g.FillRectangle(brush, x, y, barWidth, barH);

                // Value label
                var valText = $"%{p.BasariOrani:F0}";
                var valSize = g.MeasureString(valText, new Font("Segoe UI", 8, FontStyle.Bold));
                g.DrawString(valText, new Font("Segoe UI", 8, FontStyle.Bold), Brushes.Black,
                    x + (barWidth - valSize.Width) / 2, y - valSize.Height - 2);

                // Name label
                var nameSize = g.MeasureString(p.KuryeAdi, new Font("Segoe UI", 7));
                g.DrawString(p.KuryeAdi, new Font("Segoe UI", 7), Brushes.Black,
                    x + (barWidth - nameSize.Width) / 2, chartY + chartH + 3);
            }
        }

        private void BtnKuryePerformansPdf_Click(object? sender, EventArgs e)
        {
            try
            {
                var path = PdfRaporlar.KuryePerformansRaporu();
                MessageBox.Show($"Rapor oluşturuldu:\n{path}", "PDF Oluşturuldu",
                    MessageBoxButtons.OK, MessageBoxIcon.Information);
                Process.Start(new ProcessStartInfo(path) { UseShellExecute = true });
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Rapor oluşturulurken hata:\n{ex.Message}", "Hata",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

