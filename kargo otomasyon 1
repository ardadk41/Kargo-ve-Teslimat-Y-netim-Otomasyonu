using System;
using System.Data;
using System.Drawing;
using System.Windows.Forms;
using Microsoft.Data.SqlClient;
using System.Collections.Generic;

namespace KargoOtomasyon
{
    public partial class Form1 : Form
    {
        // Bağlantı cümlesi - Kendi sunucuna göre ayarlandı
        string connectionString = @"Server=localhost\SQLEXPRESS;Database=KargoOtomasyonDB;Trusted_Connection=True;TrustServerCertificate=True;";

        TextBox txtMusteriAd, txtAdres;
        ComboBox cbKuryeTip;
        Button btnSiparisEkle, btnHazirlaniyor, btnKargoyaVerildi, btnBasarili, btnBasarisiz, btnDepoOnay;
        DataGridView dgvSiparisler;

        public Form1()
        {
            this.Text = "Kargo Otomasyonu - Güvenli Süreç Yönetimi";
            this.Size = new Size(1250, 650);
            this.StartPosition = FormStartPosition.CenterScreen;
            ArayuzuOlustur();
            SiparisleriListele();
        }

        private void ArayuzuOlustur()
        {
            // --- 1. SİPARİŞ GİRİŞİ ---
            Label lblBaslik1 = new Label() { Text = "1. ADIM: SİPARİŞ KAYIT", Location = new Point(20, 10), Font = new Font(this.Font, FontStyle.Bold), AutoSize = true };
            Label lblMusteri = new Label() { Text = "Müşteri Adı:", Location = new Point(20, 40), AutoSize = true };
            txtMusteriAd = new TextBox() { Location = new Point(120, 40), Width = 200 };
            Label lblAdres = new Label() { Text = "Adres:", Location = new Point(20, 70), AutoSize = true };
            txtAdres = new TextBox() { Location = new Point(120, 70), Width = 200, Multiline = true, Height = 40 };
            Label lblTip = new Label() { Text = "Kurye Tipi:", Location = new Point(20, 120), AutoSize = true };
            cbKuryeTip = new ComboBox() { Location = new Point(120, 120), Width = 200, DropDownStyle = ComboBoxStyle.DropDownList };
            cbKuryeTip.Items.AddRange(new string[] { "Standart", "Ekspres", "AyniGun" });
            cbKuryeTip.SelectedIndex = 0;

            btnSiparisEkle = new Button() { Text = "Siparişi Kaydet", Location = new Point(120, 155), Width = 200, Height = 35, BackColor = Color.LightGreen };
            btnSiparisEkle.Click += BtnSiparisEkle_Click;

            // --- 2. SÜREÇ YÖNETİMİ ---
            Label lblBaslik2 = new Label() { Text = "2. ADIM: SÜREÇ TAKİBİ", Location = new Point(20, 210), Font = new Font(this.Font, FontStyle.Bold), AutoSize = true };
            btnHazirlaniyor = new Button() { Text = "Hazırlanıyor", Location = new Point(20, 240), Width = 145, Height = 40, BackColor = Color.LightYellow };
            btnHazirlaniyor.Click += (s, e) => DurumGuncelle("Hazırlanıyor");
            btnKargoyaVerildi = new Button() { Text = "Kargoya Verildi", Location = new Point(175, 240), Width = 145, Height = 40, BackColor = Color.Orange };
            btnKargoyaVerildi.Click += (s, e) => DurumGuncelle("Kargoya Verildi");

            // --- 3. TESLİMAT VE OTOMATİK İADE ---
            Label lblBaslik3 = new Label() { Text = "3. ADIM: TESLİMAT İŞLEMLERİ", Location = new Point(20, 300), Font = new Font(this.Font, FontStyle.Bold), AutoSize = true };
            btnBasarili = new Button() { Text = "Teslim Edildi", Location = new Point(20, 330), Width = 145, Height = 45, BackColor = Color.LightSkyBlue };
            btnBasarili.Click += (s, e) => TeslimatDene("Başarılı");
            btnBasarisiz = new Button() { Text = "Başarısız Deneme", Location = new Point(175, 330), Width = 145, Height = 45, BackColor = Color.LightCoral };
            btnBasarisiz.Click += (s, e) => TeslimatDene("Başarısız");

            // --- 4. DEPO ONAYI ---
            btnDepoOnay = new Button() { Text = "İade Edildi (Depo Onayı)", Location = new Point(20, 385), Width = 300, Height = 40, BackColor = Color.Gray, ForeColor = Color.White };
            btnDepoOnay.Click += (s, e) => DurumGuncelle("İade Edildi");

            // Liste (DataGridView)
            dgvSiparisler = new DataGridView() { Location = new Point(350, 20), Width = 870, Height = 550, ReadOnly = true, SelectionMode = DataGridViewSelectionMode.FullRowSelect, AllowUserToAddRows = false };

            this.Controls.Add(lblBaslik1); this.Controls.Add(lblMusteri); this.Controls.Add(txtMusteriAd);
            this.Controls.Add(lblAdres); this.Controls.Add(txtAdres); this.Controls.Add(lblTip);
            this.Controls.Add(cbKuryeTip); this.Controls.Add(btnSiparisEkle);
            this.Controls.Add(lblBaslik2); this.Controls.Add(btnHazirlaniyor); this.Controls.Add(btnKargoyaVerildi);
            this.Controls.Add(lblBaslik3); this.Controls.Add(btnBasarili); this.Controls.Add(btnBasarisiz);
            this.Controls.Add(btnDepoOnay); this.Controls.Add(dgvSiparisler);
        }

        // --- İŞ GÜNÜ HESAPLAMA (TATİLLERİ ATLAR) ---
        private DateTime TeslimatTarihiHesapla(DateTime baslangic, string tip)
        {
            int eklenecekGun = (tip == "Standart") ? 3 : (tip == "Ekspres") ? 1 : 0;
            if (tip == "AyniGun") return baslangic.Date;
            DateTime sonuc = baslangic.Date;
            int sayac = 0;
            while (sayac < eklenecekGun) {
                sonuc = sonuc.AddDays(1);
                if (sonuc.DayOfWeek == DayOfWeek.Saturday || sonuc.DayOfWeek == DayOfWeek.Sunday) continue;
                sayac++;
            }
            return sonuc;
        }

        private void BtnSiparisEkle_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtMusteriAd.Text)) return;
            DateTime tahmini = TeslimatTarihiHesapla(DateTime.Now, cbKuryeTip.SelectedItem.ToString());
            using (SqlConnection con = new SqlConnection(connectionString)) {
                con.Open();
                string q = "INSERT INTO Siparisler (MusteriAd, Adres, KuryeTip, TahminiTeslim, Durum) VALUES (@Ad, @Adres, @Tip, @Tahmini, 'Sipariş Alındı')";
                SqlCommand cmd = new SqlCommand(q, con);
                cmd.Parameters.AddWithValue("@Ad", txtMusteriAd.Text);
                cmd.Parameters.AddWithValue("@Adres", txtAdres.Text);
                cmd.Parameters.AddWithValue("@Tip", cbKuryeTip.SelectedItem.ToString());
                cmd.Parameters.AddWithValue("@Tahmini", tahmini);
                cmd.ExecuteNonQuery();
                SiparisleriListele();
                txtMusteriAd.Clear(); txtAdres.Clear();
            }
        }

        private void DurumGuncelle(string yeniDurum)
        {
            if (dgvSiparisler.SelectedRows.Count == 0) return;
            int id = Convert.ToInt32(dgvSiparisler.SelectedRows[0].Cells["SiparisID"].Value);
            string mevcutDurum = dgvSiparisler.SelectedRows[0].Cells["Durum"].Value.ToString();

            if (yeniDurum == "İade Edildi" && mevcutDurum != "İade Bekliyor") {
                MessageBox.Show("Yalnızca 'İade Bekliyor' olan siparişler iade edilebilir.");
                return;
            }

            using (SqlConnection con = new SqlConnection(connectionString)) {
                con.Open();
                string query = $"UPDATE Siparisler SET Durum='{yeniDurum}'";
                if (yeniDurum == "Kargoya Verildi") query += ", KargoyaVerilisTarihi=GETDATE()";
                if (yeniDurum == "İade Edildi") query += ", IadeTarihi=GETDATE()";
                query += $" WHERE SiparisID={id}";
                new SqlCommand(query, con).ExecuteNonQuery();
                SiparisleriListele();
            }
        }

        private void TeslimatDene(string sonuc)
        {
            if (dgvSiparisler.SelectedRows.Count == 0) return;
            var row = dgvSiparisler.SelectedRows[0];
            int id = Convert.ToInt32(row.Cells["SiparisID"].Value);
            string mevcutDurum = row.Cells["Durum"].Value.ToString();
            DateTime tahmini = Convert.ToDateTime(row.Cells["Tahmini"].Value);

            // GÜVENLİK ENGELİ: İade sürecindeki paket teslim edilemez
            if (mevcutDurum == "İade Bekliyor" || mevcutDurum == "İade Edildi") {
                MessageBox.Show("Bu paket iade sürecindedir, teslimat yapılamaz!");
                return;
            }

            // ERKEN TESLİMAT ENGELİ
            if (sonuc == "Başarılı" && DateTime.Now.Date < tahmini.Date) {
                MessageBox.Show($"Bu paket en erken {tahmini.ToShortDateString()} tarihinde teslim edilebilir!");
                return;
            }

            using (SqlConnection con = new SqlConnection(connectionString)) {
                con.Open();
                new SqlCommand($"INSERT INTO TeslimatDenemeleri (SiparisID, Sonuc) VALUES ({id}, '{sonuc}')", con).ExecuteNonQuery();
                
                if (sonuc == "Başarılı") {
                    new SqlCommand($"UPDATE Siparisler SET Durum='Teslim Edildi', GerceklesenTeslimTarihi=GETDATE() WHERE SiparisID={id}", con).ExecuteNonQuery();
                } else {
                    // SAYAÇ VE OTOMATİK İADE
                    int count = (int)new SqlCommand($"SELECT COUNT(*) FROM TeslimatDenemeleri WHERE SiparisID={id} AND Sonuc='Başarısız'", con).ExecuteScalar();
                    if (count >= 3) {
                        new SqlCommand($"UPDATE Siparisler SET Durum='İade Bekliyor' WHERE SiparisID={id}", con).ExecuteNonQuery();
                        MessageBox.Show("3. Başarısız deneme! Otomatik iade süreci başladı.");
                    } else {
                        MessageBox.Show($"Başarısız deneme kaydedildi. Deneme No: {count}");
                    }
                }
                SiparisleriListele();
            }
        }

        private void SiparisleriListele()
        {
            using (SqlConnection con = new SqlConnection(connectionString)) {
                con.Open();
                string sql = "SELECT SiparisID, MusteriAd, TahminiTeslim as Tahmini, Durum, KargoyaVerilisTarihi as Kargo_Saat, GerceklesenTeslimTarihi as Teslim_Saat, IadeTarihi as Iade_Saat FROM Siparisler ORDER BY SiparisID DESC";
                SqlDataAdapter da = new SqlDataAdapter(sql, con);
                DataTable dt = new DataTable();
                da.Fill(dt);
                dgvSiparisler.DataSource = dt;
            }
        }
    }
}
