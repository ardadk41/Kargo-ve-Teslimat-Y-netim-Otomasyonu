using KargoYonetim.Data;

namespace KargoYonetim.Forms
{
    public class FormMusteri : Form
    {
        private TextBox txtAdSoyad = null!, txtTelefon = null!, txtAdres = null!, txtSehir = null!;
        private DataGridView dgv = null!;
        private int selectedId = -1;

        public FormMusteri()
        {
            InitializeComponents();
            LoadData();
        }

        private void InitializeComponents()
        {
            this.Text = "👤 Müşteri Yönetimi";
            this.Size = new Size(900, 600);
            this.StartPosition = FormStartPosition.CenterParent;
            this.Font = new Font("Segoe UI", 10);
            this.BackColor = Color.FromArgb(236, 240, 241);

            // Header
            var pnlHeader = new Panel { Dock = DockStyle.Top, Height = 50, BackColor = Color.FromArgb(27, 40, 56) };
            pnlHeader.Controls.Add(new Label
            {
                Text = "  👤  Müşteri Yönetimi",
                ForeColor = Color.White,
                Font = new Font("Segoe UI", 14, FontStyle.Bold),
                Dock = DockStyle.Fill,
                TextAlign = ContentAlignment.MiddleLeft
            });


            // Input Panel
            var pnlInput = new Panel { Dock = DockStyle.Top, Height = 160, Padding = new Padding(15, 10, 15, 5), BackColor = Color.White };

            pnlInput.Controls.Add(CreateLabel("Ad Soyad:", 10, 12));
            txtAdSoyad = CreateTextBox(100, 10, 200);
            pnlInput.Controls.Add(txtAdSoyad);

            pnlInput.Controls.Add(CreateLabel("Telefon:", 320, 12));
            txtTelefon = CreateTextBox(400, 10, 180);
            txtTelefon.MaxLength = 11;
            txtTelefon.KeyPress += TxtTelefon_KeyPress;
            pnlInput.Controls.Add(txtTelefon);

            pnlInput.Controls.Add(CreateLabel("Adres:", 10, 52));
            txtAdres = CreateTextBox(100, 50, 480);
            pnlInput.Controls.Add(txtAdres);

            pnlInput.Controls.Add(CreateLabel("Şehir:", 600, 12));
            txtSehir = CreateTextBox(660, 10, 180);
            pnlInput.Controls.Add(txtSehir);

            // Buttons
            var btnEkle = CreateButton("➕ Ekle", 100, 95, Color.FromArgb(76, 175, 80));
            btnEkle.Click += BtnEkle_Click;
            pnlInput.Controls.Add(btnEkle);

            var btnGuncelle = CreateButton("✏️ Güncelle", 230, 95, Color.FromArgb(33, 150, 243));
            btnGuncelle.Click += BtnGuncelle_Click;
            pnlInput.Controls.Add(btnGuncelle);

            var btnSil = CreateButton("🗑️ Sil", 360, 95, Color.FromArgb(244, 67, 54));
            btnSil.Click += BtnSil_Click;
            pnlInput.Controls.Add(btnSil);

            var btnTemizle = CreateButton("🧹 Temizle", 490, 95, Color.FromArgb(117, 117, 117));
            btnTemizle.Click += (s, e) => ClearForm();
            pnlInput.Controls.Add(btnTemizle);



            // DataGridView
            dgv = new DataGridView
            {
                Dock = DockStyle.Fill, ReadOnly = true, AllowUserToAddRows = false, AllowUserToDeleteRows = false,
                SelectionMode = DataGridViewSelectionMode.FullRowSelect,
                AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill,
                AutoGenerateColumns = false,
                BackgroundColor = Color.White, BorderStyle = BorderStyle.None,
                RowHeadersVisible = false, Font = new Font("Segoe UI", 9),
                AlternatingRowsDefaultCellStyle = new DataGridViewCellStyle { BackColor = Color.FromArgb(245, 245, 245) },
                DefaultCellStyle = new DataGridViewCellStyle { SelectionBackColor = Color.FromArgb(33, 150, 243) }
            };
            dgv.ColumnHeadersDefaultCellStyle = new DataGridViewCellStyle
            {
                BackColor = Color.FromArgb(27, 40, 56), ForeColor = Color.White,
                Font = new Font("Segoe UI", 10, FontStyle.Bold), Padding = new Padding(5)
            };
            dgv.EnableHeadersVisualStyles = false;
            dgv.CellClick += Dgv_CellClick;

            dgv.Columns.AddRange(
                new DataGridViewTextBoxColumn { Name = "Id", DataPropertyName = "Id", HeaderText = "No", Width = 50 },
                new DataGridViewTextBoxColumn { Name = "AdSoyad", DataPropertyName = "AdSoyad", HeaderText = "Ad Soyad" },
                new DataGridViewTextBoxColumn { Name = "Telefon", DataPropertyName = "Telefon", HeaderText = "Telefon" },
                new DataGridViewTextBoxColumn { Name = "Adres", DataPropertyName = "Adres", HeaderText = "Adres" },
                new DataGridViewTextBoxColumn { Name = "Sehir", DataPropertyName = "Sehir", HeaderText = "Şehir" },
                new DataGridViewTextBoxColumn { Name = "KayitTarihi", DataPropertyName = "KayitTarihi", HeaderText = "Kayıt Tarihi" }
            );

            var pnlGrid = new Panel { Dock = DockStyle.Fill, Padding = new Padding(15, 10, 15, 15) };
            pnlGrid.Controls.Add(dgv);

            // Dock sıralaması: son eklenen en üste yerleşir
            this.Controls.Add(pnlGrid);
            this.Controls.Add(pnlInput);
            this.Controls.Add(pnlHeader);
        }

        private Label CreateLabel(string text, int x, int y)
        {
            return new Label { Text = text, Location = new Point(x, y), AutoSize = true, Font = new Font("Segoe UI", 10, FontStyle.Bold), ForeColor = Color.FromArgb(60, 60, 60) };
        }

        private TextBox CreateTextBox(int x, int y, int width)
        {
            return new TextBox { Location = new Point(x, y), Size = new Size(width, 28), Font = new Font("Segoe UI", 10), BorderStyle = BorderStyle.FixedSingle };
        }

        private Button CreateButton(string text, int x, int y, Color color)
        {
            var btn = new Button
            {
                Text = text, Location = new Point(x, y), Size = new Size(120, 36),
                FlatStyle = FlatStyle.Flat, BackColor = color, ForeColor = Color.White,
                Font = new Font("Segoe UI", 9, FontStyle.Bold), Cursor = Cursors.Hand
            };
            btn.FlatAppearance.BorderSize = 0;
            return btn;
        }

        private void LoadData()
        {
            dgv.DataSource = DatabaseHelper.GetMusteriler();
        }

        private void ClearForm()
        {
            txtAdSoyad.Clear(); txtTelefon.Clear(); txtAdres.Clear(); txtSehir.Clear();
            selectedId = -1;
            dgv.ClearSelection();
        }

        private void Dgv_CellClick(object? sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex < 0) return;
            var row = dgv.Rows[e.RowIndex];
            selectedId = Convert.ToInt32(row.Cells["Id"].Value);
            txtAdSoyad.Text = row.Cells["AdSoyad"].Value?.ToString();
            txtTelefon.Text = row.Cells["Telefon"].Value?.ToString();
            txtAdres.Text = row.Cells["Adres"].Value?.ToString();
            txtSehir.Text = row.Cells["Sehir"].Value?.ToString();
        }

        private void BtnEkle_Click(object? sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtAdSoyad.Text) || string.IsNullOrWhiteSpace(txtAdres.Text))
            { MessageBox.Show("Ad Soyad ve Adres alanları zorunludur.", "Uyarı", MessageBoxButtons.OK, MessageBoxIcon.Warning); return; }

            if (txtTelefon.Text.Length != 11)
            { MessageBox.Show("Eksik numara girildi!\nTelefon numarası 11 haneli olmalıdır. (Örn: 05XX XXX XX XX)", "Uyarı", MessageBoxButtons.OK, MessageBoxIcon.Warning); txtTelefon.Focus(); return; }

            DatabaseHelper.AddMusteri(new Musteri { AdSoyad = txtAdSoyad.Text, Telefon = txtTelefon.Text, Adres = txtAdres.Text, Sehir = txtSehir.Text });
            MessageBox.Show("Müşteri eklendi.", "Başarılı", MessageBoxButtons.OK, MessageBoxIcon.Information);
            ClearForm();
            LoadData();
        }

        private void BtnGuncelle_Click(object? sender, EventArgs e)
        {
            if (selectedId < 0) { MessageBox.Show("Güncellenecek müşteriyi seçin.", "Uyarı", MessageBoxButtons.OK, MessageBoxIcon.Warning); return; }

            if (txtTelefon.Text.Length != 11)
            { MessageBox.Show("Eksik numara girildi!\nTelefon numarası 11 haneli olmalıdır. (Örn: 05XX XXX XX XX)", "Uyarı", MessageBoxButtons.OK, MessageBoxIcon.Warning); txtTelefon.Focus(); return; }

            DatabaseHelper.UpdateMusteri(new Musteri { Id = selectedId, AdSoyad = txtAdSoyad.Text, Telefon = txtTelefon.Text, Adres = txtAdres.Text, Sehir = txtSehir.Text });
            MessageBox.Show("Müşteri güncellendi.", "Başarılı", MessageBoxButtons.OK, MessageBoxIcon.Information);
            ClearForm();
            LoadData();
        }

        private void BtnSil_Click(object? sender, EventArgs e)
        {
            if (selectedId < 0) { MessageBox.Show("Silinecek müşteriyi seçin.", "Uyarı", MessageBoxButtons.OK, MessageBoxIcon.Warning); return; }
            if (MessageBox.Show("Müşteriyi silmek istediğinize emin misiniz?\n\n⚠️ Bu müşteriye ait tüm siparişler ve ilgili kayıtlar da silinecektir!", "Onay", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
            {
                try
                {
                    DatabaseHelper.DeleteMusteri(selectedId);
                    MessageBox.Show("Müşteri başarıyla silindi.", "Başarılı", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    ClearForm();
                    LoadData();
                }
                catch (Exception ex)
                {
                    MessageBox.Show($"Müşteri silinirken bir hata oluştu:\n{ex.Message}", "Hata", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            }
        }

        private void TxtTelefon_KeyPress(object? sender, KeyPressEventArgs e)
        {
            // Sadece rakam ve Backspace'e izin ver
            if (!char.IsDigit(e.KeyChar) && !char.IsControl(e.KeyChar))
            {
                e.Handled = true;
            }
        }
    }
}
