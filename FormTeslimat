        private Button CreateButton(string text, int x, int y, Color color)
        {
            var btn = new Button
            {
                Text = text, Location = new Point(x, y), Size = new Size(120, 36),
                FlatStyle = FlatStyle.Flat, BackColor = color, ForeColor = Color.White,
                Font = new Font("Segoe UI", 9, FontStyle.Bold), Cursor = Cursors.Hand
            };
            btn.FlatAppearance.BorderSize = 0;
            return btn;
        }

        private void LoadSiparisler()
        {
            siparisler = DatabaseHelper.GetSiparisler()
                .Where(s => s.Durum != "Teslim Edildi" && s.Durum != "İptal")
                .ToList();

            cmbSiparis.DataSource = null;
            cmbSiparis.DisplayMember = "Display";
            cmbSiparis.ValueMember = "Id";

            var displayList = siparisler.Select(s => new
            {
                s.Id,
                Display = $"#{s.Id} — {s.MusteriAdi} — {s.Durum} ({s.KuryeTipi})"
            }).ToList();

            cmbSiparis.DataSource = displayList;
        }

        private void CmbSiparis_Changed(object? sender, EventArgs e)
        {
            if (cmbSiparis.SelectedValue == null) return;
            var siparisId = (int)cmbSiparis.SelectedValue;
            var siparis = DatabaseHelper.GetSiparis(siparisId);
            if (siparis == null) return;

            lblSiparisInfo.Text = $"Müşteri: {siparis.MusteriAdi} | Kurye: {siparis.KuryeAdi ?? "Atanmadı"} | " +
                $"Durum: {siparis.Durum} | Tip: {IsGunuHesaplama.KuryeTipiAdi(siparis.KuryeTipi)} | " +
                $"Tahmini: {siparis.TahminiTeslim}";

            var basarisiz = DatabaseHelper.GetBasarisizDenemeSayisi(siparisId);
            lblDenemeCount.Text = $"Başarısız Deneme: {basarisiz} / 3";
            lblDenemeCount.ForeColor = basarisiz >= 3 ? Color.FromArgb(183, 28, 28) :
                basarisiz >= 2 ? Color.FromArgb(230, 126, 34) : Color.FromArgb(27, 94, 32);

            LoadDenemeler(siparisId);
        }

        private void LoadDenemeler(int siparisId)
        {
            dgvDenemeler.DataSource = DatabaseHelper.GetDenemeler(siparisId);
        }

        private void BtnDenemeKaydet_Click(object? sender, EventArgs e)
        {
            if (cmbSiparis.SelectedValue == null)
            { MessageBox.Show("Sipariş seçin.", "Uyarı", MessageBoxButtons.OK, MessageBoxIcon.Warning); return; }

            var siparisId = (int)cmbSiparis.SelectedValue;
            var siparis = DatabaseHelper.GetSiparis(siparisId);
            if (siparis == null) return;

            // İş Kuralı: Teslim edilmiş siparişe deneme yapılamaz
            if (siparis.Durum == "Teslim Edildi")
            {
                MessageBox.Show("Teslim edilmiş siparişe teslimat denemesi yapılamaz.", "İş Kuralı",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            // İş Kuralı: İptal edilmiş siparişe deneme yapılamaz
            if (siparis.Durum == "İptal")
            {
                MessageBox.Show("İptal edilmiş siparişe teslimat denemesi yapılamaz.", "İş Kuralı",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            var sonuc = cmbSonuc.Text;

            // Denemeyi kaydet (Edge Case: Aynı gün iki deneme yapılabilir, engel yok)
            DatabaseHelper.AddDeneme(new Deneme
            {
                SiparisId = siparisId,
                Sonuc = sonuc,
                Aciklama = txtAciklama.Text
            });

            if (sonuc == "Başarılı")
            {
                // Teslim edildi
                DatabaseHelper.UpdateSiparisDurum(siparisId, "Teslim Edildi",
                    DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"));
                MessageBox.Show($"Sipariş #{siparisId} başarıyla teslim edildi! ✅", "Teslim Edildi",
                    MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            else
            {
                // Başarısız deneme — sayaç kontrolü
                var basarisiz = DatabaseHelper.GetBasarisizDenemeSayisi(siparisId);

                if (basarisiz >= 3)
                {
                    // İş Kuralı: 3 başarısız deneme → otomatik İade Bekliyor
                    DatabaseHelper.UpdateSiparisDurum(siparisId, "İade Bekliyor");
                    MessageBox.Show(
                        $"⚠️ Sipariş #{siparisId} — 3 başarısız deneme!\n" +
                        "Sipariş otomatik olarak 'İade Bekliyor' durumuna alındı.",
                        "İade Sürecine Alındı", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                }
                else
                {
                    MessageBox.Show(
                        $"Başarısız deneme kaydedildi.\nKalan deneme hakkı: {3 - basarisiz}",
                        "Başarısız Deneme", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
            }

            txtAciklama.Clear();
            LoadSiparisler();
            // Reselect the same siparis if still exists
            for (int i = 0; i < cmbSiparis.Items.Count; i++)
            {
                var item = cmbSiparis.Items[i];
                var prop = item?.GetType().GetProperty("Id");
                if (prop != null && (int)prop.GetValue(item)! == siparisId)
                {
                    cmbSiparis.SelectedIndex = i;
                    break;
                }
            }
        }

        private void BtnSifirla_Click(object? sender, EventArgs e)
        {
            if (cmbSiparis.SelectedValue == null)
            { MessageBox.Show("Sipariş seçin.", "Uyarı", MessageBoxButtons.OK, MessageBoxIcon.Warning); return; }

            if (string.IsNullOrWhiteSpace(txtSifirlamaNeden.Text))
            {
                MessageBox.Show("Sayaç sıfırlama nedeni zorunludur.\n(Kim, ne zaman, neden)", "Uyarı",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            var siparisId = (int)cmbSiparis.SelectedValue;

            if (MessageBox.Show(
                $"Sipariş #{siparisId} için sayaç sıfırlanacak.\nNeden: {txtSifirlamaNeden.Text}\n\nDevam etmek istiyor musunuz?",
                "Sayaç Sıfırlama Onayı", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
            {
                // Edge Case: Sayaç sıfırlandıktan sonra sayaç 1'den başlar
                DatabaseHelper.SayacSifirla(siparisId, txtSifirlamaNeden.Text);
                MessageBox.Show("Sayaç sıfırlandı. Log kaydı oluşturuldu.", "Başarılı",
                    MessageBoxButtons.OK, MessageBoxIcon.Information);
                txtSifirlamaNeden.Clear();
                CmbSiparis_Changed(null, EventArgs.Empty);
            }
        }

        private void DgvDenemeler_CellFormatting(object? sender, DataGridViewCellFormattingEventArgs e)
        {
            if (dgvDenemeler.Columns[e.ColumnIndex].Name == "Sonuc" && e.Value != null)
            {
                e.CellStyle.Font = new Font("Segoe UI", 9, FontStyle.Bold);
                if (e.Value.ToString() == "Başarılı")
                {
                    e.CellStyle.ForeColor = Color.FromArgb(27, 94, 32);
                    e.CellStyle.BackColor = Color.FromArgb(232, 245, 233);
                }
                else
                {
                    e.CellStyle.ForeColor = Color.FromArgb(183, 28, 28);
                    e.CellStyle.BackColor = Color.FromArgb(255, 235, 238);
                }
            }
        }
